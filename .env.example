# Copie este arquivo para .env.local e preencha os valores
# Todas as variáveis devem começar com VITE_ para serem expostas ao frontend

# URL da API backend (FastAPI) — deixe vazio para usar localStorage (modo offline)
VITE_API_URL=

# Modo de dados: "local" (localStorage) ou "api" (backend real)
VITE_DATA_MODE=local

# Versão do app (exibida no rodapé ou about)
VITE_APP_VERSION=1.0.0
